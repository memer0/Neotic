# Neotic Backend Configuration

# Gemini API Key (Required)
GOOGLE_API_KEY=your-gemini-v2-flash-api-key

# Supabase JWT Secret (Optional for local development if DISABLE_AUTH=true)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase Credentials (Optional if DISABLE_AUTH=true)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server Settings
PORT=8001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth Bypass (Set to "true" for local development without Supabase)
DISABLE_AUTH=true

# Optional Caching (Redis)
# REDIS_URL=redis://localhost:6379
