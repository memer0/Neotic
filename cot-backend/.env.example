SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard


NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server
PORT=8080

# Auth
# Set to "true" to bypass JWT validation during local development ONLY.
DISABLE_AUTH=false

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Redis cache (optional — cache is disabled if unset)
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# Kafka (optional — Kafka integration is disabled if unset)
KAFKA_BROKERS=localhost:9092
