# ------------------------------------------------------------------------------
# NEOTIC MASTER ENVIRONMENT TEMPLATE
# Instructions:
# 1. Copy this file and rename it to ".env.local" in the root directory for Next.js.
# 2. Copy this file again and rename it to ".env" inside /server for FastAPI.
# 3. Fill in the values from your Firebase Project and Google AI Studio.
# ------------------------------------------------------------------------------

# 1. FRONTEND CONFIGURATION (NEXT.JS)
# ==============================================================================

# Backend SSL Testing URL
NEXT_PUBLIC_API_URL=https://localhost:8001

# Set to true to bypass Firebase auth for local development
NEXT_PUBLIC_DISABLE_AUTH=false

# Firebase Project Settings (Public Keys)
# Obtain from Firebase Console -> Project Settings -> General -> Web Apps
# Note: These must exactly match the values in your project
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:00000000000000000"


# 2. BACKEND CONFIGURATION (FASTAPI SERVER)
# ==============================================================================

# Gemini AI Reasoning Core API Key (Required)
# Obtain from Google AI Studio: https://aistudio.google.com/
GOOGLE_API_KEY="your-gemini-v2-flash-api-key"

# Server Port Configuration
PORT=8001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Backend Auth Bypass (Set to "true" for local backend testing without Firebase tokens)
DISABLE_AUTH=false

# Optional Caching (Redis)
# REDIS_URL=redis://localhost:6379
